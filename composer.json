{
    "name": "develler/remediation-agent",
    "description": "Develler agent for Laravel — real-time PII masking and automated code-fix pipeline",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/redis": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "nikic/php-parser": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Develler\\RemediationAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Develler\\RemediationAgent\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Develler\\RemediationAgent\\RemediationServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
